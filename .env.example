# ── Frontend (Vite) ─────────────────────────────────────
# Absolute base URL of the API, INCLUDING the /api suffix. Leave BLANK for local
# dev — the Vite dev server proxies /api to http://localhost:4000 (vite.config.ts).
# In production this MUST be set to the deployed API origin, e.g.
#   VITE_API_BASE_URL=https://tennisai-api.onrender.com/api
VITE_API_BASE_URL=

# Use the in-memory mock auth instead of the real backend (frontend-only dev).
# VITE_MOCK_AUTH=true

# Opt in to the live tournaments API (only once server/src/tournaments exists).
# VITE_LIVE_TOURNAMENTS=true
