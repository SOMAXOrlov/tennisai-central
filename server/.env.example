# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# PostgreSQL. For local dev, `docker compose up -d` starts one matching this URL.
DATABASE_URL="postgresql://tennisai:tennisai@localhost:5432/tennisai?schema=public"

# Auth. In production this MUST be a strong random string (>= 32 chars); the app
# refuses to boot with a default/short secret when NODE_ENV=production.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="dev-only-insecure-secret-change-me"
JWT_EXPIRES_IN="1d"

# URL of the frontend (used for CORS + links inside emails). No trailing slash.
APP_URL="http://localhost:5180"

# ── Gmail (optional) ────────────────────────────────────
# When BOTH GMAIL_USER and GMAIL_APP_PASSWORD are set, a real welcome
# email is sent via Gmail on every new signup. Leave them blank to just
# log the email to the server console (no real send, no credentials needed).
#
# To enable real sending:
#   1. Turn on 2-Step Verification on the Gmail account.
#   2. Google Account > Security > App passwords > create one for "Mail".
#   3. Paste the 16-character password below (spaces are fine).
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
MAIL_FROM_NAME="TennisAI"
