// TennisAI database schema.
// Provider is PostgreSQL — the same engine is used in dev and production
// (dev/prod parity). For local dev, run a Postgres via `docker compose up -d`
// (see server/docker-compose.yml) and point DATABASE_URL at it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  publicId      String   @unique // shareable directory id, e.g. TAI-P-001
  passwordHash  String
  role          String // "player" | "coach" | "observer" | "admin"
  firstName     String
  lastName      String
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // back-relations (trainings domain)
  coachedTrainings       Training[]            @relation("TrainingCoach")
  trainingParticipations TrainingParticipant[]
  // back-relations (tournaments domain)
  playerTournaments      PlayerTournament[]
  // back-relations (teams domain)
  coachedTeams    Team[]       @relation("TeamCoach")
  teamMemberships TeamMember[]
  // back-relations (connections domain)
  sentConnections     ConnectionRequest[] @relation("ConnFrom")
  receivedConnections ConnectionRequest[] @relation("ConnTo")

  @@map("users")
}

// ── Trainings domain ─────────────────────────────────────────────
// Mirrors the front-end `TrainingSession` shape (src/types/index.ts).
// `playerIds[]` is normalised into the TrainingParticipant join table.
// The nested review / feedback / analysis objects are stored as JSON.

model Training {
  id                    String    @id @default(cuid())
  title                 String
  description           String?
  trainingType          String // individual | team | match_practice | fitness | recovery | tactical
  coachId               String
  teamId                String? // FK relation added when the teams domain migrates
  startDate             DateTime
  endDate               DateTime
  location              String?
  goal                  String?
  intensity             String? // low | medium | high
  notes                 String?
  coachNotes            String?
  review                Json? // TrainingReview
  playerSessionFeedback Json? // PlayerSessionFeedback
  analysis              Json? // TrainingAnalysis
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  coach        User                  @relation("TrainingCoach", fields: [coachId], references: [id], onDelete: Cascade)
  participants TrainingParticipant[]

  @@index([coachId])
  @@index([startDate])
  @@map("trainings")
}

model TrainingParticipant {
  id         String   @id @default(cuid())
  trainingId String
  playerId   String
  createdAt  DateTime @default(now())

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  player   User     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([trainingId, playerId])
  @@index([playerId])
  @@map("training_participants")
}

// ── Tournaments domain ───────────────────────────────────────────
// A global catalog (Tournament) plus a per-player join (PlayerTournament).
// Mirrors the front-end `Tournament` / `PlayerTournament` shapes.

model Tournament {
  id             String   @id @default(cuid())
  name           String
  city           String
  country        String
  surface        String
  indoorOutdoor  String // indoor | outdoor
  altitude       Int?
  ballBrand      String?
  weatherSummary String?
  category       String?
  level          String?
  federation     String? // ITF | WTA | ATP | UTR | USTA
  startDate      DateTime
  endDate        DateTime
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  playerEntries PlayerTournament[]

  @@index([startDate])
  @@map("tournaments")
}

model PlayerTournament {
  id           String   @id @default(cuid())
  tournamentId String
  playerId     String
  status       String // planned | registered | maybe | withdrawn | played
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     User       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([playerId])
  @@map("player_tournaments")
}

// ── Teams domain ─────────────────────────────────────────────────
// A coach-owned team with player members. The front-end `Team.players`
// (ConnectedPlayer[]) is composed from the TeamMember join + User.

model Team {
  id        String   @id @default(cuid())
  name      String
  coachId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach   User         @relation("TeamCoach", fields: [coachId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@index([coachId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  playerId String
  joinedAt DateTime @default(now()) // → ConnectedPlayer.connectedSince

  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player User @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@index([playerId])
  @@map("team_members")
}

// ── Connections domain ───────────────────────────────────────────
// A directed relationship request between two users. Denormalised
// names/roles in the front-end shape are derived from the User join.

model ConnectionRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  status     String   @default("pending") // pending | active | rejected | revoked
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fromUser User @relation("ConnFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ConnTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([status])
  @@map("connection_requests")
}
