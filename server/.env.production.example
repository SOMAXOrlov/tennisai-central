# Production backend env (Render). Set these in the host's env store — never commit real values.
NODE_ENV=production
PORT=4000

# Managed Postgres connection string (Render provides this automatically when
# you link the database in render.yaml). Most providers require SSL:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tennisai?sslmode=require"

# REQUIRED: strong random secret (>= 32 chars). The app will not boot without it.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=""
JWT_EXPIRES_IN="1d"

# Exact deployed frontend origin — used for CORS. No trailing slash, no path.
APP_URL="https://your-frontend.vercel.app"

# Optional Gmail welcome emails.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
MAIL_FROM_NAME="TennisAI"
